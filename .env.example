# =============================================================================
# ZenAndOps - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables are required — docker-compose.yml has no defaults.
# =============================================================================

# --- Project Version ---
# Must match the version in pom.xml / package.json
ZENANDOPS_VERSION=1.1.0

# --- MongoDB ---
MONGODB_PORT=27017
MONGODB_ROOT_USERNAME=zenandops
MONGODB_ROOT_PASSWORD=zenandops
AUTH_DB_NAME=zenandops-auth

# --- Kafka ---
KAFKA_PORT=9092

# --- Auth Service ---
AUTH_SERVICE_PORT=8081

# --- Dashboard Service ---
DASHBOARD_SERVICE_PORT=8082

# --- Gateway Service ---
GATEWAY_SERVICE_PORT=8080
GATEWAY_AUTH_SERVICE_URL=http://auth-service:8081
GATEWAY_DASHBOARD_SERVICE_URL=http://dashboard-service:8082
GATEWAY_RATE_LIMIT_MAX_REQUESTS=100
GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60

# --- Frontend ---
FRONTEND_PORT=3000

# --- JWT Configuration ---
JWT_ISSUER=https://zenandops.com
JWT_PUBLIC_KEY_LOCATION=publicKey.pem
JWT_PRIVATE_KEY_LOCATION=privateKey.pem
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_HOURS=8
