# =============================================================================
# ZenAndOps - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables have sensible defaults defined in docker-compose.yml.
# =============================================================================

# --- MongoDB ---
MONGODB_PORT=27017
MONGODB_ROOT_USERNAME=zenandops
MONGODB_ROOT_PASSWORD=zenandops
AUTH_DB_NAME=zenandops-auth

# --- Kafka ---
KAFKA_PORT=9092

# --- Auth Service ---
AUTH_SERVICE_PORT=8081

# --- Dashboard Service ---
DASHBOARD_SERVICE_PORT=8082

# --- Frontend ---
FRONTEND_PORT=3000

# --- JWT Configuration ---
JWT_ISSUER=https://zenandops.com
JWT_PUBLIC_KEY_LOCATION=publicKey.pem
JWT_PRIVATE_KEY_LOCATION=privateKey.pem
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_HOURS=8
